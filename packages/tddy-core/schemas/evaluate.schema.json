{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/evaluate",
  "title": "EvaluateOutput",
  "type": "object",
  "required": ["goal"],
  "properties": {
    "goal": { "const": "evaluate-changes" },
    "summary": { "type": "string" },
    "risk_level": { "type": "string" },
    "build_results": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/build-result" }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/issue" }
    },
    "changeset_sync": { "$ref": "urn:tddy:common/changeset-sync" },
    "files_analyzed": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/file-analyzed" }
    },
    "test_impact": { "$ref": "urn:tddy:common/test-impact" },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "change_type"],
        "properties": {
          "path": { "type": "string" },
          "change_type": { "type": "string" },
          "lines_added": { "type": "integer" },
          "lines_removed": { "type": "integer" }
        }
      }
    },
    "affected_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "properties": {
          "path": { "type": "string" },
          "status": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "validity_assessment": { "type": "string" }
  }
}

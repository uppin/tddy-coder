{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/red",
  "title": "RedOutput",
  "type": "object",
  "required": ["goal", "summary"],
  "properties": {
    "goal": { "const": "red" },
    "summary": { "type": "string" },
    "tests": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/test-info" }
    },
    "skeletons": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/skeleton-info" }
    },
    "test_command": { "type": "string" },
    "prerequisite_actions": { "type": "string" },
    "run_single_or_selected_tests": { "type": "string" },
    "markers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["marker_id", "test_name", "scope"],
        "properties": {
          "marker_id": { "type": "string" },
          "test_name": { "type": "string" },
          "scope": { "type": "string" },
          "source_file": { "type": "string" },
          "data": {}
        }
      }
    },
    "marker_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["marker_id", "test_name", "scope", "collected"],
        "properties": {
          "marker_id": { "type": "string" },
          "test_name": { "type": "string" },
          "scope": { "type": "string" },
          "collected": { "type": "boolean" },
          "investigation": { "type": ["string", "null"] }
        }
      }
    },
    "test_output_file": { "type": "string" },
    "sequential_command": { "type": "string" },
    "logging_command": { "type": "string" },
    "metric_hooks": { "type": "string" },
    "feedback_options": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/validate",
  "title": "ValidateOutput",
  "type": "object",
  "required": ["goal"],
  "properties": {
    "goal": { "const": "validate-changes" },
    "summary": { "type": "string" },
    "risk_level": { "type": "string" },
    "build_results": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/build-result" }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/issue" }
    },
    "changeset_sync": { "$ref": "urn:tddy:common/changeset-sync" },
    "files_analyzed": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/file-analyzed" }
    },
    "test_impact": { "$ref": "urn:tddy:common/test-impact" }
  }
}

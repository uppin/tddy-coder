{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/validate-subagents",
  "title": "ValidateSubagentsOutput",
  "type": "object",
  "required": ["goal", "refactoring_plan"],
  "properties": {
    "goal": { "const": "validate" },
    "summary": { "type": "string" },
    "tests_report_written": { "type": "boolean" },
    "prod_ready_report_written": { "type": "boolean" },
    "clean_code_report_written": { "type": "boolean" },
    "refactoring_plan_written": { "type": "boolean" },
    "refactoring_plan": {
      "type": "string",
      "minLength": 1,
      "description": "Markdown body for refactoring-plan.md (required). Use a no-op heading if no tasks."
    }
  }
}

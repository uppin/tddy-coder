{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:tool/changeset-workflow",
  "title": "ChangesetWorkflowPayload",
  "type": "object",
  "properties": {
    "run_optional_step_x": { "type": "boolean" },
    "demo_options": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool_schema_id": { "type": "string" },
    "branch_worktree_intent": {
      "type": "string",
      "enum": ["new_branch_from_base", "work_on_selected_branch"]
    },
    "selected_integration_base_ref": { "type": "string" },
    "new_branch_name": { "type": "string" },
    "selected_branch_to_work_on": { "type": "string" },
    "github_pr_tools_metadata": {
      "type": "object",
      "properties": {
        "mcp_tool_names": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "post_workflow_open_github_pr": { "type": "boolean" },
    "post_workflow_remove_session_worktree": { "type": "boolean" },
    "github_pr_status": {
      "type": "object",
      "properties": {
        "phase": { "type": "string" },
        "url": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] }
      },
      "required": ["phase", "url", "error"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

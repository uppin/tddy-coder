{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/acceptance-tests",
  "title": "AcceptanceTestsOutput",
  "type": "object",
  "required": ["goal", "summary"],
  "properties": {
    "goal": { "const": "acceptance-tests" },
    "summary": { "type": "string" },
    "tests": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/test-info" }
    },
    "test_command": { "type": "string" },
    "prerequisite_actions": { "type": "string" },
    "run_single_or_selected_tests": { "type": "string" },
    "sequential_command": { "type": "string" },
    "logging_command": { "type": "string" },
    "metric_hooks": { "type": "string" },
    "feedback_options": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tddy:goal/green",
  "title": "GreenOutput",
  "type": "object",
  "required": ["goal", "summary"],
  "properties": {
    "goal": { "const": "green" },
    "summary": { "type": "string" },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file", "status"],
        "properties": {
          "name": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "status": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "implementations": {
      "type": "array",
      "items": { "$ref": "urn:tddy:common/skeleton-info" }
    },
    "test_command": { "type": "string" },
    "prerequisite_actions": { "type": "string" },
    "run_single_or_selected_tests": { "type": "string" },
    "demo_results": {
      "type": "object",
      "required": ["summary", "steps_completed"],
      "properties": {
        "summary": { "type": "string" },
        "steps_completed": { "type": "integer" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Update-Docs Goal Output",
  "description": "Structured output from the update-docs goal.",
  "type": "object",
  "required": ["goal", "summary", "docs_updated"],
  "properties": {
    "goal": {
      "type": "string",
      "const": "update-docs"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "docs_updated": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}

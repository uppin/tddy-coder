{
  "name": "tddy-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cypress:component": "ELECTRON_EXTRA_LAUNCH_ARGS='--disable-gpu --no-sandbox' cypress run --component",
    "cypress:component:debug": "DEBUG=cypress:* bun run cypress:component",
    "cypress:e2e": "bun run build-storybook && node scripts/e2e-serve-and-test.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cypress": "^14.0.0",
    "get-port": "^7.1.0",
    "serve": "^14.2.0",
    "start-server-and-test": "^2.0.3",
    "storybook": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}

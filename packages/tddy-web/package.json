{
  "name": "tddy-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cypress:component": "ELECTRON_EXTRA_LAUNCH_ARGS='--disable-gpu --no-sandbox' cypress run --component",
    "cypress:component:debug": "DEBUG=cypress:* bun run cypress:component",
    "cypress:e2e": "bun run build-storybook && start-server-and-test 'npx http-server storybook-static -p 9786 -c-1 --cors' http://localhost:9786/iframe.html 'ELECTRON_EXTRA_LAUNCH_ARGS=\"--disable-gpu --no-sandbox\" CYPRESS_BASE_URL=http://localhost:9786 cypress run --e2e'"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cypress": "^14.0.0",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.0.0",
    "storybook": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}

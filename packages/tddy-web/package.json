{
  "name": "tddy-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "bunx buf generate ../tddy-service/proto",
    "prebuild": "bun run --cwd ../tddy-livekit-web build && node scripts/gen-build-id.mjs",
    "build": "vite build",
    "test": "bun run cypress:component && bun run cypress:e2e",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0",
    "build-storybook": "storybook build",
    "cypress:component": "ELECTRON_EXTRA_LAUNCH_ARGS='--disable-gpu --no-sandbox' cypress run --component",
    "cypress:component:debug": "DEBUG=cypress:* bun run cypress:component",
    "cypress:e2e": "bun run build-storybook && start-server-and-test 'npx http-server storybook-static -p 9786 -c-1 --cors' http://localhost:9786/iframe.html 'ELECTRON_EXTRA_LAUNCH_ARGS=\"--disable-gpu --no-sandbox\" CYPRESS_BASE_URL=http://localhost:9786 cypress run --e2e'",
    "cypress:e2e:spec": "bun run build-storybook && start-server-and-test 'npx http-server storybook-static -p 9786 -c-1 --cors' http://localhost:9786/iframe.html 'ELECTRON_EXTRA_LAUNCH_ARGS=\"--disable-gpu --no-sandbox\" CYPRESS_BASE_URL=http://localhost:9786 cypress run --e2e --spec \"${CYPRESS_SPEC:-cypress/e2e/ghostty-terminal.cy.ts}\"'",
    "cypress:e2e:connect": "bun run build && cypress run --e2e --spec cypress/e2e/app-connect-flow.cy.ts",
    "cypress:e2e:auth": "bun run build && node cypress/scripts/run-auth-e2e.mjs",
    "cypress:serve": "bun run build-storybook && ./run-cypress-serve.sh"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ghostty-web": "^0.4.0",
    "livekit-client": "^2.17.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/react": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cypress": "^14.0.0",
    "http-server": "^14.1.1",
    "livekit-server-sdk": "^2.15.0",
    "shadcn": "^4.1.1",
    "start-server-and-test": "^2.0.0",
    "storybook": "^9.0.0",
    "tddy-livekit-web": "workspace:*",
    "tesseract.js": "^5.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}

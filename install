#!/usr/bin/env bash
# Install tddy-daemon (and tddy-coder, tddy-tools) as a systemd service.
#
# Usage: sudo ./install --systemd [--build]
#
#   --systemd   Required. Install release binaries, config template, unit file; enable+start service.
#   --build     Optional. Run ./release before copying binaries.
#
# Optional (from repo root): ./dev bun install — installs @zed-industries/codex-acp and the
# platform-specific native package under node_modules/. When that native binary exists, it is
# copied to INSTALL_BIN_DIR/codex-acp. Install fails only if bundling is mandatory (see below).
#
# Mandatory bundling: daemon.yaml (existing or freshly created from daemon.yaml.production) must
# list `id: codex-acp` under allowed_agents, or set INSTALL_BUNDLE_CODEX_ACP=1. Otherwise a missing
# or unsupported-platform npm package is skipped (use TDDY_CODEX_ACP_CLI / PATH at runtime).
#
# Environment (install paths — override for tests or non-FHS layouts):
#   INSTALL_PREFIX       Base prefix (default: /usr/local). Binaries go to INSTALL_PREFIX/bin
#                        unless INSTALL_BIN_DIR is set.
#   INSTALL_BIN_DIR      Destination for binaries (default: ${INSTALL_PREFIX}/bin).
#   INSTALL_CONFIG_DIR   Config directory (default: /etc/tddy); daemon.yaml lives here.
#   INSTALL_SYSTEMD_DIR   systemd unit directory (default: /etc/systemd/system).
#   INSTALL_WEB_BUNDLE_DIR  Directory for tddy-web static files (default: ${INSTALL_PREFIX}/share/tddy/web).
#
#   INSTALL_NO_SYSTEMCTL=1  Skip root check and systemctl (for automated tests).
#
#   INSTALL_BUNDLE_CODEX_ACP=1  Always install ${BIN_DIR}/codex-acp from node_modules; fail if the
#                        platform package or native binary is missing.
#
#   INSTALL_OVERWRITE_SYSTEMD_UNIT=1  Replace tddy-daemon.service with the template from this script.
#                        Default: if the unit file already exists, it is not overwritten (preserves
#                        User=, Group=, drop-ins content in the main file, ExecStart edits, etc.).
#
# Progress: lines prefixed with "install:" go to stdout (paths, files touched, log dirs).
set -euo pipefail
cd "$(dirname "$0")"

ROOT_DIR="$(pwd)"
BIN_DIR="${INSTALL_BIN_DIR:-${INSTALL_PREFIX:-/usr/local}/bin}"
WEB_BUNDLE_DIR="${INSTALL_WEB_BUNDLE_DIR:-${INSTALL_PREFIX:-/usr/local}/share/tddy/web}"
CONFIG_DIR="${INSTALL_CONFIG_DIR:-/etc/tddy}"
SYSTEMD_DIR="${INSTALL_SYSTEMD_DIR:-/etc/systemd/system}"
WEB_DIST_SRC="${ROOT_DIR}/packages/tddy-web/dist"
CONFIG_FILE="${CONFIG_DIR}/daemon.yaml"
UNIT_PATH="${SYSTEMD_DIR}/tddy-daemon.service"
NO_SYSTEMCTL="${INSTALL_NO_SYSTEMCTL:-0}"
OVERWRITE_SYSTEMD_UNIT="${INSTALL_OVERWRITE_SYSTEMD_UNIT:-0}"

# The unprivileged OS user/group the daemon runs as (see the systemd unit below). Configurable so
# nothing is hardcoded; set INSTALL_DAEMON_USER=root for multi-user setuid spawning instead.
DAEMON_USER="${INSTALL_DAEMON_USER:-tddy}"
DAEMON_GROUP="${INSTALL_DAEMON_GROUP:-$DAEMON_USER}"

# Group that gates access to the local Unix socket (docker-model). systemd creates the socket
# as root via tddy-daemon.socket and chowns it to ${DAEMON_USER}:${SOCKET_GROUP} mode 0660, so
# same-host clients (tddy-sandbox-app, and humans added to this group) can connect without root.
SOCKET_GROUP="${INSTALL_SOCKET_GROUP:-tddy-clients}"
UNIT_SOCKET_PATH="${SYSTEMD_DIR}/tddy-daemon.socket"
# Where systemd creates the local socket. Must match daemon.yaml local.socket_path (the daemon's
# fallback when unset is /run/tddy-daemon.sock, which matches this default).
SOCKET_LISTEN_PATH="${INSTALL_SOCKET_PATH:-/run/tddy-daemon.sock}"

# AppArmor profile granting the unprivileged user namespaces the Linux cgroups sandbox needs.
APPARMOR_DIR="${INSTALL_APPARMOR_DIR:-/etc/apparmor.d}"
APPARMOR_PROFILE_SRC="${ROOT_DIR}/packages/tddy-daemon/apparmor/tddy-daemon"
APPARMOR_PROFILE_PATH="${APPARMOR_DIR}/tddy-daemon"

# Paths referenced by daemon.yaml.production (log + auth); children use per-repo tmp/logs at runtime.
DAEMON_LOG_DIR="/var/log/tddy-daemon"
AUTH_STORAGE_DIR="/var/lib/tddy"

want_systemd=false
want_build=false
for arg in "$@"; do
  case "$arg" in
    --systemd) want_systemd=true ;;
    --build) want_build=true ;;
    *)
      echo "Unknown option: $arg" >&2
      echo "Usage: $0 --systemd [--build]" >&2
      exit 1
      ;;
  esac
done

if ! "$want_systemd"; then
  echo "Usage: $0 --systemd [--build]" >&2
  exit 1
fi

if [[ "$NO_SYSTEMCTL" != "1" ]]; then
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "install: must run as root (use sudo) or set INSTALL_NO_SYSTEMCTL=1 for test installs" >&2
    exit 1
  fi
fi

if "$want_build"; then
  echo "install: running ${ROOT_DIR}/release"
  "${ROOT_DIR}/release"
fi

for name in tddy-daemon tddy-coder tddy-tools; do
  src="${ROOT_DIR}/target/release/${name}"
  if [[ ! -f "$src" ]]; then
    echo "install: missing release binary: ${src}" >&2
    echo "install: run ./release first or use --build" >&2
    exit 1
  fi
done

if [[ ! -f "${WEB_DIST_SRC}/index.html" ]]; then
  echo "install: missing built tddy-web bundle: ${WEB_DIST_SRC}/index.html" >&2
  echo "install: run from repo root: ./dev bun run build  (or: cd packages/tddy-web && bun run build)" >&2
  exit 1
fi

# Native codex-acp from bun/npm optional platform package (see package.json dependencies).
compute_codex_acp_native_src() {
  local os arch
  case "$(uname -s)" in
    Linux) os=linux ;;
    Darwin) os=darwin ;;
    *) return 1 ;;
  esac
  case "$(uname -m)" in
    x86_64|amd64) arch=x64 ;;
    aarch64|arm64) arch=arm64 ;;
    *) return 1 ;;
  esac
  echo "${ROOT_DIR}/node_modules/@zed-industries/codex-acp-${os}-${arch}/bin/codex-acp"
  return 0
}

# True when install must place ${BIN_DIR}/codex-acp from node_modules (fail if missing/unsupported).
codex_acp_bundling_mandatory() {
  if [[ "${INSTALL_BUNDLE_CODEX_ACP:-0}" == "1" ]]; then
    return 0
  fi
  local cfg
  if [[ -f "$CONFIG_FILE" ]]; then
    cfg="$CONFIG_FILE"
  else
    cfg="${ROOT_DIR}/daemon.yaml.production"
  fi
  [[ -f "$cfg" ]] || return 1
  # Agent id line under allowed_agents (YAML: optional quotes).
  grep -Eq '^[[:space:]]*id:[[:space:]]*['\''"]?codex-acp['\''"]?[[:space:]]*$' "$cfg"
}

install_codex_acp_from_node_modules() {
  local src=""
  if ! src="$(compute_codex_acp_native_src)"; then
    if codex_acp_bundling_mandatory; then
      echo "install: bundled codex-acp has no @zed-industries package mapping for $(uname -s)/$(uname -m)" >&2
      exit 1
    fi
    echo "install: skipping codex-acp (no npm platform package for this OS/CPU)"
    return 0
  fi

  if [[ -f "$src" ]]; then
    install -m 0755 "$src" "${BIN_DIR}/codex-acp"
    echo "install:   updated ${BIN_DIR}/codex-acp (from @zed-industries/codex-acp platform package)"
    return 0
  fi

  if codex_acp_bundling_mandatory; then
    echo "install: missing codex-acp native binary: ${src}" >&2
    echo "install: run from repo root: ./dev bun install  (pulls @zed-industries/codex-acp + platform package)" >&2
    echo "install: or drop codex-acp from allowed_agents / unset INSTALL_BUNDLE_CODEX_ACP if you do not use this backend" >&2
    exit 1
  fi

  echo "install: skipping codex-acp (native binary not under node_modules; not required by daemon config)"
}

echo "install: paths — BIN_DIR=${BIN_DIR}"
echo "install: paths — CONFIG_DIR=${CONFIG_DIR} (daemon.yaml)"
echo "install: paths — SYSTEMD_DIR=${SYSTEMD_DIR}"
echo "install: paths — WEB_BUNDLE_DIR=${WEB_BUNDLE_DIR}"
echo "install: logging — daemon process file log (from daemon.yaml.production): ${DAEMON_LOG_DIR}/daemon"
echo "install: logging — OAuth/token storage (auth_storage): ${AUTH_STORAGE_DIR}"
echo "install: logging — spawned tddy-coder sessions write under each repo: <repo>/tmp/logs/coder and <repo>/tmp/logs/child/ (runtime; not created by this script)"
echo "install: per–OS-user spawn PATH (e.g. Cursor agent): ~/.tddy/config.yaml on the target user (spawn_path_extra); not created by this script"
echo "install: codex-acp — if present under node_modules, copied to \${BIN_DIR}/codex-acp (mandatory when allowed_agents lists id codex-acp or INSTALL_BUNDLE_CODEX_ACP=1)"

mkdir -p "$BIN_DIR" "$CONFIG_DIR" "$SYSTEMD_DIR" "$WEB_BUNDLE_DIR"

if [[ "$NO_SYSTEMCTL" != "1" ]]; then
  if [[ "$DAEMON_USER" != "root" ]]; then
    echo "install: ensuring service user/group ${DAEMON_USER}:${DAEMON_GROUP}"
    if ! getent group "$DAEMON_GROUP" >/dev/null; then
      groupadd --system "$DAEMON_GROUP"
    fi
    if ! id -u "$DAEMON_USER" >/dev/null 2>&1; then
      useradd --system --gid "$DAEMON_GROUP" --home-dir "$AUTH_STORAGE_DIR" \
        --shell /usr/sbin/nologin "$DAEMON_USER"
    fi
  fi
  echo "install: ensuring socket-access group ${SOCKET_GROUP} (add same-host client users with: usermod -aG ${SOCKET_GROUP} <user>)"
  if ! getent group "$SOCKET_GROUP" >/dev/null; then
    groupadd --system "$SOCKET_GROUP"
  fi
  echo "install: ensuring system dirs for daemon log + auth: ${DAEMON_LOG_DIR}, ${AUTH_STORAGE_DIR}"
  mkdir -p "$DAEMON_LOG_DIR" "$AUTH_STORAGE_DIR"
  echo "install: chowning ${DAEMON_LOG_DIR} and ${AUTH_STORAGE_DIR} to ${DAEMON_USER}:${DAEMON_GROUP}"
  chown -R "${DAEMON_USER}:${DAEMON_GROUP}" "$DAEMON_LOG_DIR" "$AUTH_STORAGE_DIR"
fi

echo "install: installing binaries -> ${BIN_DIR}/"
install -m 0755 "${ROOT_DIR}/target/release/tddy-daemon" "${BIN_DIR}/tddy-daemon"
echo "install:   updated ${BIN_DIR}/tddy-daemon"
install -m 0755 "${ROOT_DIR}/target/release/tddy-coder" "${BIN_DIR}/tddy-coder"
echo "install:   updated ${BIN_DIR}/tddy-coder"
install -m 0755 "${ROOT_DIR}/target/release/tddy-tools" "${BIN_DIR}/tddy-tools"
echo "install:   updated ${BIN_DIR}/tddy-tools"
install_codex_acp_from_node_modules

echo "install: copying web static bundle ${WEB_DIST_SRC}/ -> ${WEB_BUNDLE_DIR}/"
cp -a "${WEB_DIST_SRC}/." "$WEB_BUNDLE_DIR/"
echo "install:   web bundle deployed (e.g. index.html)"

if [[ ! -f "$CONFIG_FILE" ]]; then
  if [[ ! -f "${ROOT_DIR}/daemon.yaml.production" ]]; then
    echo "install: missing ${ROOT_DIR}/daemon.yaml.production" >&2
    exit 1
  fi
  echo "install: creating ${CONFIG_FILE} from daemon.yaml.production (placeholders: __INSTALL_BIN_DIR__, __WEB_BUNDLE_PATH__)"
  sed -e "s#__INSTALL_BIN_DIR__#${BIN_DIR}#g" -e "s#__WEB_BUNDLE_PATH__#${WEB_BUNDLE_DIR}#g" \
    "${ROOT_DIR}/daemon.yaml.production" >"$CONFIG_FILE"
  chmod 0644 "$CONFIG_FILE"
else
  echo "install: keeping existing config (not overwriting): ${CONFIG_FILE}"
fi

if [[ -f "$UNIT_PATH" ]] && [[ "$OVERWRITE_SYSTEMD_UNIT" != "1" ]]; then
  echo "install: keeping existing systemd unit (not overwriting): ${UNIT_PATH}"
  echo "install:   set INSTALL_OVERWRITE_SYSTEMD_UNIT=1 to replace with this script's template (ExecStart, User=, etc.)"
else
  echo "install: writing systemd unit ${UNIT_PATH}"
  cat >"$UNIT_PATH" <<UNIT
[Unit]
Description=tddy-daemon multi-user daemon
After=network.target
# The socket unit creates the local Unix socket (as root, group ${SOCKET_GROUP}) and passes the
# listening fd to this service via socket activation, so the unprivileged daemon never has to bind
# in /run itself. Requires= keeps them lifecycled together.
Requires=tddy-daemon.socket
After=tddy-daemon.socket

[Service]
Type=simple
ExecStart=${BIN_DIR}/tddy-daemon -c ${CONFIG_FILE}
Restart=on-failure
RestartSec=5
# Runs unprivileged as ${DAEMON_USER}. Delegate=yes hands the service a writable cgroup v2 subtree so
# the Linux sandbox can create per-session scopes with memory/cpu/pids limits; AppArmorProfile grants
# the unprivileged user namespaces the sandbox needs (Ubuntu 24.04 restricts these by default).
# NOTE: as a non-root user the daemon spawns sessions as itself (same_user=true) — multi-user setuid
# spawning needs root: re-run with INSTALL_DAEMON_USER=root (Delegate=/AppArmorProfile= are then
# harmless but unnecessary). Ensure auth_storage, config dir, and listen port are usable by the user.
User=${DAEMON_USER}
Group=${DAEMON_GROUP}
Delegate=yes
AppArmorProfile=tddy-daemon

[Install]
WantedBy=multi-user.target
UNIT
  chmod 0644 "$UNIT_PATH"
  echo "install:   ExecStart=${BIN_DIR}/tddy-daemon -c ${CONFIG_FILE}"
fi

if [[ -f "$UNIT_SOCKET_PATH" ]] && [[ "$OVERWRITE_SYSTEMD_UNIT" != "1" ]]; then
  echo "install: keeping existing systemd socket unit (not overwriting): ${UNIT_SOCKET_PATH}"
  echo "install:   set INSTALL_OVERWRITE_SYSTEMD_UNIT=1 to replace with this script's template (SocketGroup, ListenStream, etc.)"
else
  echo "install: writing systemd socket unit ${UNIT_SOCKET_PATH} (ListenStream=${SOCKET_LISTEN_PATH}, group ${SOCKET_GROUP})"
  cat >"$UNIT_SOCKET_PATH" <<SOCKET
[Unit]
Description=tddy-daemon local ConnectionService socket

[Socket]
# systemd creates this socket as root, then chowns it to ${DAEMON_USER}:${SOCKET_GROUP} at mode 0660
# (the docker.sock model). Same-host clients in ${SOCKET_GROUP} can connect; the daemon adopts the
# passed fd via LISTEN_FDS. Must match daemon.yaml local.socket_path (unset -> ${SOCKET_LISTEN_PATH}).
ListenStream=${SOCKET_LISTEN_PATH}
SocketUser=${DAEMON_USER}
SocketGroup=${SOCKET_GROUP}
SocketMode=0660

[Install]
WantedBy=sockets.target
SOCKET
  chmod 0644 "$UNIT_SOCKET_PATH"
  echo "install:   ListenStream=${SOCKET_LISTEN_PATH} SocketUser=${DAEMON_USER} SocketGroup=${SOCKET_GROUP} SocketMode=0660"
fi

# AppArmor profile granting the daemon binary unprivileged user namespaces. Loaded before the service
# starts because the unit's AppArmorProfile= transition fails if the profile is not present.
if [[ "$NO_SYSTEMCTL" != "1" ]]; then
  if [[ -f "$APPARMOR_PROFILE_SRC" ]]; then
    echo "install: installing AppArmor profile -> ${APPARMOR_PROFILE_PATH} (userns grant for ${BIN_DIR}/tddy-daemon)"
    mkdir -p "$APPARMOR_DIR"
    sed -e "s#__INSTALL_BIN_DIR__#${BIN_DIR}#g" "$APPARMOR_PROFILE_SRC" >"$APPARMOR_PROFILE_PATH"
    chmod 0644 "$APPARMOR_PROFILE_PATH"
    if command -v apparmor_parser >/dev/null 2>&1; then
      apparmor_parser -r "$APPARMOR_PROFILE_PATH"
      echo "install:   AppArmor profile loaded"
    else
      echo "install:   WARNING: apparmor_parser not found; profile written but not loaded" >&2
    fi
  else
    echo "install: WARNING: AppArmor profile source missing: ${APPARMOR_PROFILE_SRC}" >&2
  fi
fi

if [[ "$NO_SYSTEMCTL" != "1" ]]; then
  echo "install: systemctl daemon-reload; enable + start tddy-daemon.socket and tddy-daemon"
  systemctl daemon-reload
  # Start the socket first so the listening fd exists before the service is (re)started and adopts it.
  systemctl enable tddy-daemon.socket
  systemctl restart tddy-daemon.socket
  systemctl enable tddy-daemon
  systemctl restart tddy-daemon
  echo "install: done (socket + service started). journal: journalctl -u tddy-daemon -f"
  echo "install: verify socket: ls -l ${SOCKET_LISTEN_PATH}  (expect srw-rw---- ${DAEMON_USER}:${SOCKET_GROUP})"
else
  echo "install: done (INSTALL_NO_SYSTEMCTL=1: skipped systemctl; skipped mkdir ${DAEMON_LOG_DIR} and ${AUTH_STORAGE_DIR}; skipped enable/start)"
fi

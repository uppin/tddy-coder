# Vite bind (not the browser URL — use VITE_URL for that)
WEB_HOST=127.0.0.1
VITE_PORT=5173

# Origin users open in the browser (OAuth, HMR app). Default is http://127.0.0.1:5173 when unset.
# Set when accessing from another machine, e.g. WEB_HOST=0.0.0.0 and VITE_URL=http://192.168.1.10:5173
# VITE_URL=http://192.168.1.10:5173

# LIVEKIT_PUBLIC_URL=ws://192.168.1.10:7880

# Config file (default: dev.config.yaml)
CONFIG=dev.config.yaml

# LiveKit testkit (used by ./test for auto-start, and by ./web-dev if set)
# LIVEKIT_TESTKIT_WS_URL=ws://127.0.0.1:7880

# GitHub OAuth (real provider — alternative to github.stub in config)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

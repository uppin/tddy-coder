# Web dev server (0.0.0.0 = accessible from network, 127.0.0.1 = localhost only)
WEB_HOST=127.0.0.1
VITE_PORT=5173

# Public URLs for browser-facing access from other machines.
# Set these when WEB_HOST=0.0.0.0 and accessing remotely.
# WEB_PUBLIC_URL=http://192.168.1.10:8899
# LIVEKIT_PUBLIC_URL=ws://192.168.1.10:7880

# Config file (default: dev.config.yaml)
CONFIG=dev.config.yaml

# LiveKit testkit (used by ./test for auto-start, and by ./web-dev if set)
# LIVEKIT_TESTKIT_WS_URL=ws://127.0.0.1:7880

# GitHub OAuth (real provider — alternative to github.stub in config)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

#!/usr/bin/env bash
# Run verification (cargo test) and write output to .verify-result.txt.
# Agent can read this file when terminal output capture is broken (Cursor bug).
# Run from nix shell: ./dev, then ./verify  (or: nix develop -c ./verify)
set -e
set -o pipefail
cd "$(dirname "$0")"
# tddy-integration-tests ACP cases spawn target/debug/tddy-acp-stub (not a lib dependency).
cargo build -p tddy-acp-stub
cargo test -- --test-threads=1 2>&1 | tee .verify-result.txt

{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Bash(./dev*)",
      "Bash(./test*)",
      "Bash(./verify*)",
      "Bash(./release*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo clippy*)",
      "Bash(cargo fmt*)",
      "Bash(bun test*)",
      "Bash(bun run*)",
      "Bash(bunx cypress*)",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Read(//etc/**)",
      "Read(//root/**)",
      "Read(//home/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/**)",
      "Read(~/.claude/**)",
      "Edit(//etc/**)",
      "Edit(//root/**)",
      "Edit(//home/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.config/**)",
      "Edit(~/.claude/**)",
      "Write(//etc/**)",
      "Write(//root/**)",
      "Write(//home/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.config/**)",
      "Write(~/.claude/**)"
    ],
    "deny": [
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)"
    ]
  }
}

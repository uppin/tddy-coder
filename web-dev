#!/usr/bin/env bash
# Start tddy-daemon (RPC backend) + Vite dev server (HMR frontend).
#
# Vite proxies /rpc → daemon. Edit React code and see changes instantly.
#
# Usage: ./web-dev                        # tddy-daemon with dev.daemon.yaml (see DAEMON_CONFIG)
#        ./web-dev -c my-config.yaml     # extra CLI for tddy-daemon (pass-through)
#        ./web-dev --github-stub         # e.g. extra CLI overrides
#        ./web-dev --headless            # daemon/worker only; no Vite dev server, no web bundle needed
#
# Environment variables:
#   WEB_HOST        — Address Vite listens on (default: 127.0.0.1). Use 0.0.0.0 for LAN. Separate from
#                     the URL you open in the browser — set VITE_URL for that.
#   VITE_PORT       — Port for Vite dev server (default: 5173)
#   VITE_URL        — **Only env you need for “where is the app?”** Browser-facing origin (OAuth,
#                     import.meta.env.VITE_URL). Default: http://127.0.0.1:<VITE_PORT>. LAN example:
#                     VITE_URL=http://192.168.1.10:5173 (host must match how you open the page).
#                     web-dev exports WEB_PUBLIC_URL=$VITE_URL for tddy-daemon (do not set WEB_PUBLIC_URL
#                     for web-dev; a stale value in .env is overridden).
#   DAEMON_CONFIG   — YAML for tddy-daemon (default: dev.daemon.yaml at repo root).
#                     CONFIG from .env is not used for the daemon backend; use DAEMON_CONFIG.
#   TDDY_DAEMON_INSTANCE_ID — Override the daemon's LiveKit instance id (its participant identity in
#                     the shared room). Overrides daemon_instance_id in the YAML; default is the
#                     YAML value (dev) or the machine hostname. Inherited by tddy-daemon via env.
#   LIVEKIT_PUBLIC_URL — Override LiveKit URL (tddy-daemon); e.g. ws://192.168.1.10:7880
#   LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET — LiveKit overrides (tddy-daemon)
#   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, GITHUB_REDIRECT_URI — GitHub OAuth (tddy-daemon)
#   TDDY_TELEGRAM_BOT_TOKEN, TDDY_TELEGRAM_CHAT_IDS, TDDY_TELEGRAM_ENABLED — Telegram (tddy-daemon);
#                     see docs/ft/daemon/telegram-notifications.md
#
# Press Ctrl+C to stop both servers.
set -euo pipefail
cd "$(dirname "$0")"

# Load .env if present (does not override already-set env vars)
if [ -f .env ]; then
  while IFS='=' read -r key value; do
    # Skip comments and blank lines
    [[ -z "$key" || "$key" == \#* ]] && continue
    # Strip surrounding quotes from value
    value="${value%\"}" ; value="${value#\"}"
    value="${value%\'}" ; value="${value#\'}"
    # Only set if not already in environment
    if [ -z "${!key+x}" ]; then
      export "$key=$value"
    fi
  done < .env
fi

# --headless: launch only tddy-daemon (RPC/worker backend); skip the Vite dev server.
# In this mode no web bundle is needed. The flag is consumed here and not passed to the daemon.
HEADLESS=false
filtered_args=()
for arg in "$@"; do
  if [ "$arg" = "--headless" ]; then
    HEADLESS=true
  else
    filtered_args+=("$arg")
  fi
done
set -- "${filtered_args[@]+"${filtered_args[@]}"}"

WEB_HOST="${WEB_HOST:-127.0.0.1}"
VITE_PORT="${VITE_PORT:-5173}"
# Daemon YAML path for this script (not the generic CONFIG env var from .env).
# DAEMON_CONFIG overrides; default is dev.daemon.yaml at repo root.
CONFIG="${DAEMON_CONFIG:-dev.daemon.yaml}"

daemon_args=()
if [ -f "$CONFIG" ]; then
  # Replace CURRENT_USER with $USER in a temp copy (daemon config uses os_user).
  # Use | as delimiter so slashes in paths inside YAML are not conflated with sed's replacement.
  TMP_CONFIG=$(mktemp)
  sed "s|CURRENT_USER|${USER}|g" "$CONFIG" > "$TMP_CONFIG"
  trap 'rm -f "$TMP_CONFIG"' EXIT
  daemon_args+=("-c" "$TMP_CONFIG")
else
  echo "tddy-daemon requires -c CONFIG. ${CONFIG} not found." >&2
  exit 1
fi

# Pass through all user args (may include -c, --github-stub, etc.). If the user also passes -c,
# the daemon may receive two -c flags; effective config is daemon-defined. DAEMON_PORT below still
# comes from the CONFIG path selected above (not from a second -c on the CLI).
daemon_args+=("$@")

# Read daemon port from config for the Vite proxy (same file as CONFIG / DAEMON_CONFIG).
# Supports web.port (tddy-coder) and listen.web_port (tddy-daemon)
DAEMON_PORT=$(grep -E 'port:\s*[0-9]+' "$CONFIG" 2>/dev/null | head -1 | awk '{print $2}')
DAEMON_PORT="${DAEMON_PORT:-8899}"

# Public origin for OAuth / SPA: VITE_URL only (not WEB_HOST — that is bind-only).
# Default matches local dev; override VITE_URL for LAN. Do not read WEB_PUBLIC_URL here — .env often
# points it at the daemon port by mistake; we always set WEB_PUBLIC_URL from VITE_URL for the daemon.
if [ -z "${VITE_URL:-}" ]; then
  VITE_URL="http://127.0.0.1:${VITE_PORT}"
fi
VITE_URL="${VITE_URL%/}"
export VITE_URL
export WEB_PUBLIC_URL="${VITE_URL}"

echo "=== Starting tddy-daemon on :${DAEMON_PORT} (config: ${CONFIG}) ==="
echo "=== VITE_URL=${VITE_URL} (open this in the browser; OAuth redirect base for daemon) ==="

# Readiness uses GET /api/config (always 200 when the daemon is up). Do not use GET / alone:
# without packages/tddy-web/dist (run: ./dev bun run build), static / may 404 while RPC is fine.
if [ "$HEADLESS" != "true" ] && [ ! -f packages/tddy-web/dist/index.html ]; then
  echo "=== Note: packages/tddy-web/dist/index.html missing — open the Vite URL above for HMR; optional: ./dev bun run build for daemon static bundle ===" >&2
fi

# Clean up stale processes from previous runs. SIGKILLs listeners on these ports; on a shared
# machine, ensure ports are free or avoid conflicts before running ./web-dev.
# In headless mode the Vite port is never used, so leave it alone.
if [ "$HEADLESS" = "true" ]; then
  fuser -k -9 -s "${DAEMON_PORT}/tcp" 2>/dev/null || true
else
  fuser -k -9 -s "${DAEMON_PORT}/tcp" "${VITE_PORT}/tcp" 2>/dev/null || true
fi
sleep 2

# Ensure writable build output dirs exist before the daemon starts.
mkdir -p tmp/buildroot/disks tmp/buildroot/dl

# Build and start daemon via cargo run so source changes are picked up automatically.
./dev cargo run -p tddy-daemon -- "${daemon_args[@]}" &
daemon_pid=$!

# Wait for daemon to be ready (HTTP 200 on /api/config, verified twice to avoid race)
# nix + daemon can take 10–15s on first run; allow 90s
daemon_ready=false
for i in $(seq 1 180); do
  code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${DAEMON_PORT}/api/config" 2>/dev/null || echo "000")
  if [ "$code" = "200" ]; then
    sleep 1
    code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${DAEMON_PORT}/api/config" 2>/dev/null || echo "000")
    if [ "$code" = "200" ]; then
      daemon_ready=true
      break
    fi
  fi
  sleep 0.5
done
if [ "$daemon_ready" != "true" ]; then
  echo "Error: daemon did not respond with HTTP 200 on http://127.0.0.1:${DAEMON_PORT}/api/config within 90s." >&2
  echo "Check tmp/logs/daemon for errors. Port may be in use: fuser ${DAEMON_PORT}/tcp" >&2
  kill -9 -"$daemon_pid" 2>/dev/null || true
  exit 1
fi

# Headless: daemon/worker only. No Vite dev server, no web bundle. Wait on the daemon.
if [ "$HEADLESS" = "true" ]; then
  echo ""
  echo "=== Headless mode: tddy-daemon running on :${DAEMON_PORT} (no Vite dev server) ==="
  echo "  Daemon (RPC):  http://127.0.0.1:${DAEMON_PORT}"
  echo ""

  headless_cleanup() {
    kill -TERM -"$daemon_pid" 2>/dev/null || true
    sleep 2
    kill -KILL -"$daemon_pid" 2>/dev/null || true
    sleep 1
    fuser -k -9 -s "${DAEMON_PORT:-8899}/tcp" 2>/dev/null || true
    exit 0
  }
  trap headless_cleanup INT TERM

  wait "$daemon_pid" 2>/dev/null || true
  echo "Daemon exited — stopping" >&2
  headless_cleanup
fi

echo ""
echo "=== Starting Vite dev server on ${WEB_HOST}:${VITE_PORT} ==="
echo ""
echo "  --- Hot reload (HMR) ---"
echo "  Use the Vite dev URL below. Edits under packages/tddy-web/ apply live."
echo "  Do NOT use the daemon port for frontend dev: it serves packages/tddy-web/dist"
echo "  (last production build) and has no Vite / HMR."
echo ""
echo "  App (HMR):     ${VITE_URL}"
echo "  Daemon (RPC):  http://127.0.0.1:${DAEMON_PORT}  — static dist; /rpc and /api proxied by Vite"
echo ""

# Start Vite dev server with DAEMON_PORT for proxy config (run via ./dev for nix env)
./dev bash -c "cd packages/tddy-web && DAEMON_PORT='$DAEMON_PORT' WEB_PUBLIC_URL='$WEB_PUBLIC_URL' VITE_URL='$VITE_URL' bunx vite --port '$VITE_PORT' --host '$WEB_HOST'" &
vite_pid=$!

# Cleanup and exit. Kill by port (most reliable) since process groups may not
# include all descendants (nix → daemon → spawn_worker).
cleanup() {
  kill -TERM -"$daemon_pid" -"$vite_pid" 2>/dev/null || true
  sleep 2
  kill -KILL -"$daemon_pid" -"$vite_pid" 2>/dev/null || true
  sleep 1
  fuser -k -9 -s "${DAEMON_PORT:-8899}/tcp" "${VITE_PORT:-5173}/tcp" 2>/dev/null || true
  exit 0
}
trap cleanup INT TERM

# Wait for either process to exit
wait -n "$daemon_pid" "$vite_pid" 2>/dev/null || true
if ! kill -0 "$daemon_pid" 2>/dev/null; then
  echo "Daemon exited unexpectedly — stopping" >&2
fi
if ! kill -0 "$vite_pid" 2>/dev/null; then
  echo "Vite exited unexpectedly — stopping" >&2
fi
cleanup

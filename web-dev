#!/usr/bin/env bash
# Start tddy-coder/tddy-daemon (RPC backend) + Vite dev server (HMR frontend).
#
# Vite proxies /rpc → daemon. Edit React code and see changes instantly.
#
# Usage: ./web-dev                        # uses dev.config.yaml (tddy-demo)
#        TDDY_USE_DAEMON=1 ./web-dev      # uses tddy-daemon with dev.daemon.yaml
#        ./web-dev -c my-config.yaml      # custom config
#        ./web-dev --github-stub          # extra CLI overrides
#
# Environment variables:
#   WEB_HOST        — Host to bind Vite (default: 127.0.0.1)
#   VITE_PORT       — Port for Vite dev server (default: 5173)
#   TDDY_USE_DAEMON — If set, use tddy-daemon instead of tddy-demo
#   DAEMON_CONFIG — Config for tddy-daemon (default: dev.daemon.yaml when TDDY_USE_DAEMON=1)
#   LIVEKIT_PUBLIC_URL — Override LiveKit URL (tddy-daemon and tddy-demo); e.g. ws://192.168.1.10:7880
#   LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET — LiveKit overrides (tddy-daemon)
#   WEB_HOST, WEB_PUBLIC_URL — Bind host and public URL for auth callback (tddy-daemon)
#   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, GITHUB_REDIRECT_URI — GitHub OAuth (tddy-daemon)
#
# Press Ctrl+C to stop both servers.
set -euo pipefail
cd "$(dirname "$0")"

# Load .env if present (does not override already-set env vars)
if [ -f .env ]; then
  while IFS='=' read -r key value; do
    # Skip comments and blank lines
    [[ -z "$key" || "$key" == \#* ]] && continue
    # Strip surrounding quotes from value
    value="${value%\"}" ; value="${value#\"}"
    value="${value%\'}" ; value="${value#\'}"
    # Only set if not already in environment
    if [ -z "${!key+x}" ]; then
      export "$key=$value"
    fi
  done < .env
fi

WEB_HOST="${WEB_HOST:-127.0.0.1}"
VITE_PORT="${VITE_PORT:-5173}"
USE_DAEMON="${TDDY_USE_DAEMON:-0}"
if [ "$USE_DAEMON" = "1" ]; then
  # tddy-daemon requires dev.daemon.yaml format; ignore CONFIG from .env
  CONFIG="${DAEMON_CONFIG:-dev.daemon.yaml}"
else
  CONFIG="${CONFIG:-dev.config.yaml}"
fi

# Find binary: tddy-daemon when TDDY_USE_DAEMON=1, else tddy-demo
find_binary() {
  if [ "$USE_DAEMON" = "1" ]; then
    local debug="target/debug/tddy-daemon"
    local release="target/release/tddy-daemon"
    if [ -f "$debug" ]; then echo "$debug"; return; fi
    if [ -f "$release" ]; then echo "$release"; return; fi
    echo "tddy-daemon binary not found. Run: cargo build -p tddy-daemon" >&2
    exit 1
  else
    local debug="target/debug/tddy-demo"
    local release="target/release/tddy-demo"
    if [ -f "$debug" ]; then echo "$debug"; return; fi
    if [ -f "$release" ]; then echo "$release"; return; fi
    echo "tddy-demo binary not found. Run: cargo build -p tddy-demo" >&2
    exit 1
  fi
}

binary=$(find_binary)

daemon_args=()
if [ "$USE_DAEMON" = "1" ]; then
  if [ -f "$CONFIG" ]; then
    # Replace CURRENT_USER with $USER in a temp copy (daemon config uses os_user)
    TMP_CONFIG=$(mktemp)
    sed "s/CURRENT_USER/${USER}/g" "$CONFIG" > "$TMP_CONFIG"
    trap "rm -f $TMP_CONFIG" EXIT
    daemon_args+=("-c" "$TMP_CONFIG")
  else
    echo "tddy-daemon requires -c CONFIG. dev.daemon.yaml not found." >&2
    exit 1
  fi
else
  has_config=false
  for arg in "$@"; do
    if [ "$arg" = "-c" ] || [ "$arg" = "--config" ]; then
      has_config=true
      break
    fi
  done
  if [ "$has_config" = false ] && [ -f "$CONFIG" ]; then
    daemon_args+=("-c" "$CONFIG")
  fi
fi

# Pass through all user args (may include -c, --github-stub, etc.)
daemon_args+=("$@")

if [ "$USE_DAEMON" != "1" ]; then
  # tddy-demo/tddy-coder: WEB_HOST and URL overrides
  daemon_args+=("--web-host" "$WEB_HOST")
  if [ -n "${WEB_PUBLIC_URL:-}" ]; then
    daemon_args+=("--web-public-url" "$WEB_PUBLIC_URL")
  fi
  if [ -n "${LIVEKIT_PUBLIC_URL:-}" ]; then
    daemon_args+=("--livekit-public-url" "$LIVEKIT_PUBLIC_URL")
  fi
fi

# Read daemon port from config for the Vite proxy.
# Supports web.port (tddy-coder) and listen.web_port (tddy-daemon)
DAEMON_PORT=$(grep -E 'port:\s*[0-9]+' "$CONFIG" 2>/dev/null | head -1 | awk '{print $2}')
DAEMON_PORT="${DAEMON_PORT:-8899}"

if [ "$USE_DAEMON" = "1" ]; then
  echo "=== Starting tddy-daemon on :${DAEMON_PORT} (config: ${CONFIG}) ==="
else
  echo "=== Starting tddy-coder daemon on :${DAEMON_PORT} (config: ${CONFIG}) ==="
fi

# Clean up stale processes from previous runs
fuser -k -9 -s "${DAEMON_PORT}/tcp" "${VITE_PORT}/tcp" 2>/dev/null || true
sleep 2

# Start daemon via ./dev (nix may take 5–10s to load the binary) so CLI args are passed correctly to the tddy binary
./dev "$binary" "${daemon_args[@]}" &
daemon_pid=$!

# Wait for daemon to be ready (HTTP 200, verified twice to avoid race)
# nix + daemon can take 10–15s on first run; allow 90s
daemon_ready=false
for i in $(seq 1 180); do
  code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${DAEMON_PORT}/" 2>/dev/null || echo "000")
  if [ "$code" = "200" ]; then
    sleep 1
    code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${DAEMON_PORT}/" 2>/dev/null || echo "000")
    if [ "$code" = "200" ]; then
      daemon_ready=true
      break
    fi
  fi
  sleep 0.5
done
if [ "$daemon_ready" != "true" ]; then
  echo "Error: daemon did not respond with HTTP 200 on port ${DAEMON_PORT} within 90s." >&2
  echo "Check tmp/logs/daemon for errors. Port may be in use: fuser ${DAEMON_PORT}/tcp" >&2
  kill -9 -"$daemon_pid" 2>/dev/null || true
  exit 1
fi

echo ""
echo "=== Starting Vite dev server on ${WEB_HOST}:${VITE_PORT} ==="
if [ -n "${WEB_PUBLIC_URL:-}" ]; then
  # Extract host from WEB_PUBLIC_URL (e.g. http://192.168.1.10:8899 -> 192.168.1.10)
  PUBLIC_HOST=$(echo "$WEB_PUBLIC_URL" | sed -n 's|.*://\([^:/]*\).*|\1|p')
  if [ -n "$PUBLIC_HOST" ]; then
    echo "=== Open http://${PUBLIC_HOST}:${VITE_PORT} (app) or http://${PUBLIC_HOST}:${DAEMON_PORT} (backend) ==="
  else
    echo "=== Open http://${WEB_HOST}:${VITE_PORT} ==="
  fi
else
  echo "=== Open http://${WEB_HOST}:${VITE_PORT} ==="
fi
echo ""

# Start Vite dev server with DAEMON_PORT for proxy config (run via ./dev for nix env)
./dev bash -c "cd packages/tddy-web && DAEMON_PORT='$DAEMON_PORT' npx vite --port '$VITE_PORT' --host '$WEB_HOST'" &
vite_pid=$!

# Cleanup and exit. Kill by port (most reliable) since process groups may not
# include all descendants (nix → daemon → spawn_worker).
cleanup() {
  kill -TERM -"$daemon_pid" -"$vite_pid" 2>/dev/null || true
  sleep 2
  kill -KILL -"$daemon_pid" -"$vite_pid" 2>/dev/null || true
  sleep 1
  fuser -k -9 -s "${DAEMON_PORT:-8899}/tcp" "${VITE_PORT:-5173}/tcp" 2>/dev/null || true
  exit 0
}
trap cleanup INT TERM

# Wait for either process to exit
wait -n "$daemon_pid" "$vite_pid" 2>/dev/null || true
if ! kill -0 "$daemon_pid" 2>/dev/null; then
  echo "Daemon exited unexpectedly — stopping" >&2
fi
if ! kill -0 "$vite_pid" 2>/dev/null; then
  echo "Vite exited unexpectedly — stopping" >&2
fi
cleanup

#!/usr/bin/env bash
# Remove stale Cargo build fingerprints and deps. Keeps only the newest fingerprint per crate
# in target/debug/build, target/release/build, target/debug/deps, target/release/deps.
# Run from repo root.
set -euo pipefail
cd "$(dirname "$0")"

clean_build_dir() {
  local build_dir="$1"
  [[ -d "$build_dir" ]] || return 0

  # Collect unique crate names (strip -{16hex} suffix from dir names)
  local crate_names
  crate_names=$(for d in "$build_dir"/*/; do
    [[ -d "$d" ]] || continue
    basename "${d%/}" | sed -E 's/-[a-f0-9]{16}$//'
  done | sort -u)

  for crate_name in $crate_names; do
    [[ -n "$crate_name" ]] || continue
    local matches=()
    for d in "$build_dir/${crate_name}"-*/; do
      [[ -d "$d" ]] && matches+=("$d")
    done

    if [[ ${#matches[@]} -gt 1 ]]; then
      # Sort by mtime, newest first; remove all but the newest
      local sorted
      sorted=($(ls -td "${matches[@]}" 2>/dev/null))
      local keep="${sorted[0]}"
      for d in "${sorted[@]}"; do
        if [[ "$d" != "$keep" ]]; then
          echo "Removing stale: $d"
          rm -rf "$d"
        fi
      done
    fi
  done
}

clean_deps_dir() {
  local deps_dir="$1"
  [[ -d "$deps_dir" ]] || return 0

  # Deps files: libcrate-{16hex}.rlib, crate-{16hex}, etc. Group by prefix (crate id).
  local prefixes
  prefixes=$(cd "$deps_dir" && for f in *; do
    [[ -e "$f" ]] || continue
    echo "$f" | sed -E 's/-[a-f0-9]{16}(\.[a-z0-9]+)?$//'
  done | sort -u)

  for prefix in $prefixes; do
    [[ -n "$prefix" ]] || continue
    local matches=()
    for f in "$deps_dir/${prefix}"-*; do
      [[ -e "$f" ]] || continue
      # Must match -{16hex}.ext or -{16hex} (no ext)
      [[ "$(basename "$f")" =~ ^"${prefix}"-[a-f0-9]{16}(\.[a-z0-9]+)?$ ]] && matches+=("$f")
    done

    if [[ ${#matches[@]} -eq 0 ]]; then
      continue
    fi
    local hash_groups
    hash_groups=$(printf '%s\n' "${matches[@]}" | while read -r f; do
      basename "$f" | sed -E 's/.*-([a-f0-9]{16})(\.[a-z0-9]+)?$/\1/'
    done | sort -u)
    local num_hashes
    num_hashes=$(echo "$hash_groups" | grep -c . 2>/dev/null || echo 0)
    if [[ $num_hashes -gt 1 ]]; then
      # Group by hash: files with same hash stay together. Keep newest hash group.
      local hash_to_files
      hash_to_files=$(printf '%s\n' "${matches[@]}" | while read -r f; do
        local base
        base=$(basename "$f")
        local hash
        hash=$(echo "$base" | sed -E 's/.*-([a-f0-9]{16})(\.[a-z0-9]+)?$/\1/')
        [[ -n "$hash" ]] && echo "$hash $f"
      done)
      local hash_groups
      hash_groups=$(echo "$hash_to_files" | awk '{print $1}' | sort -u)
      local keep_hash=""
      local newest_mtime=0
      for h in $hash_groups; do
        local first_file
        first_file=$(echo "$hash_to_files" | awk -v h="$h" '$1==h {print $2; exit}')
        [[ -z "$first_file" ]] && continue
        local mtime
        mtime=$(stat -f %m "$first_file" 2>/dev/null || stat -c %Y "$first_file" 2>/dev/null)
        if [[ $mtime -gt $newest_mtime ]]; then
          newest_mtime=$mtime
          keep_hash=$h
        fi
      done
      for h in $hash_groups; do
        [[ "$h" == "$keep_hash" ]] && continue
        for f in "$deps_dir/${prefix}-${h}"*; do
          [[ -e "$f" ]] || continue
          echo "Removing stale: $f"
          rm -f "$f"
        done
      done
    fi
  done
}

echo "Cleaning stale debug fingerprints..."
clean_build_dir "target/debug/build"
echo "Cleaning stale release fingerprints..."
clean_build_dir "target/release/build"
echo "Cleaning stale deps (largest disk usage)..."
clean_deps_dir "target/debug/deps"
clean_deps_dir "target/release/deps"
echo "Done."

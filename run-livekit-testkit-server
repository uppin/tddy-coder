#!/usr/bin/env bash
# Launch or reuse a LiveKit server container and print connection details.
#
# Reuses existing container "tddy-livekit-testkit" if running. Otherwise creates it.
# This avoids spawning a new container on each test run.
#
# Usage:
#   ./run-livekit-testkit-server
#
# Output (to stdout):
#   LIVEKIT_TESTKIT_WS_URL=ws://127.0.0.1:PORT
#   (and instructions for reuse)
#
# To reuse in tests:
#   export LIVEKIT_TESTKIT_WS_URL=ws://127.0.0.1:PORT
#   cargo test -p tddy-livekit -p tddy-livekit-testkit
#
# Or: eval $(./run-livekit-testkit-server | grep '^export ')
#
# Requires Docker. Uses livekit/livekit-server:master with --dev mode.

set -euo pipefail

LIVEKIT_IMAGE="livekit/livekit-server:master"
LIVEKIT_PORT=7880
LIVEKIT_ICE_TCP_PORT=7881
LIVEKIT_ICE_UDP_PORT=7882
CONTAINER_NAME="tddy-livekit-testkit"

# Check for existing running container
existing=$(docker ps -q -f "name=^${CONTAINER_NAME}$" 2>/dev/null || true)
if [[ -n "${existing}" ]]; then
  echo "Reusing existing LiveKit container: ${CONTAINER_NAME}" >&2
  host_port=$(docker port "${CONTAINER_NAME}" "${LIVEKIT_PORT}" 2>/dev/null | sed -n 's/.*://p')
  if [[ -z "${host_port:-}" ]]; then
    echo "Failed to get port from existing container" >&2
    exit 1
  fi
  ws_url="ws://127.0.0.1:${host_port}"
else
  # Check for stopped container - start it
  stopped=$(docker ps -aq -f "name=^${CONTAINER_NAME}$" 2>/dev/null || true)
  if [[ -n "${stopped}" ]]; then
    echo "Starting existing container: ${CONTAINER_NAME}" >&2
    docker start "${CONTAINER_NAME}" >/dev/null
    sleep 2
    host_port=$(docker port "${CONTAINER_NAME}" "${LIVEKIT_PORT}" 2>/dev/null | sed -n 's/.*://p')
    if [[ -z "${host_port:-}" ]]; then
      echo "Failed to get port from started container" >&2
      exit 1
    fi
    ws_url="ws://127.0.0.1:${host_port}"
  else
    # Create new container with fixed name for reuse.
    # Expose WebRTC ICE ports (7881 TCP, 7882 UDP) with fixed mapping so advertised
    # candidates work. --node-ip 127.0.0.1 so ICE uses localhost.
    echo "Creating new LiveKit container: ${CONTAINER_NAME}" >&2
    docker run -d --name "${CONTAINER_NAME}" \
      -p "0:${LIVEKIT_PORT}" \
      -p "${LIVEKIT_ICE_TCP_PORT}:${LIVEKIT_ICE_TCP_PORT}" \
      -p "${LIVEKIT_ICE_UDP_PORT}:${LIVEKIT_ICE_UDP_PORT}/udp" \
      "${LIVEKIT_IMAGE}" --dev --bind 0.0.0.0 --node-ip 127.0.0.1

    echo "Waiting for LiveKit HTTP endpoint..." >&2
    for _ in $(seq 1 30); do
      port_line=$(docker port "${CONTAINER_NAME}" "${LIVEKIT_PORT}" 2>/dev/null)
      host_port=$(echo "${port_line}" | sed -n 's/.*://p')
      if [[ -n "${host_port:-}" ]]; then
        if curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:${host_port}/" 2>/dev/null | grep -q 200; then
          break
        fi
      fi
      sleep 1
    done

    host_port=$(docker port "${CONTAINER_NAME}" "${LIVEKIT_PORT}" 2>/dev/null | sed -n 's/.*://p')
    if [[ -z "${host_port:-}" ]]; then
      echo "Failed to get container port" >&2
      exit 1
    fi
    ws_url="ws://127.0.0.1:${host_port}"
  fi
fi

echo ""
echo "export LIVEKIT_TESTKIT_WS_URL=${ws_url}"
echo ""
echo "LiveKit testkit server at ${ws_url} (container: ${CONTAINER_NAME})"
echo "WebRTC ICE ports: ${LIVEKIT_ICE_TCP_PORT} (TCP), ${LIVEKIT_ICE_UDP_PORT} (UDP)"
echo ""
echo "To run tests against this instance:"
echo "  export LIVEKIT_TESTKIT_WS_URL=${ws_url}"
echo "  cargo test -p tddy-livekit -p tddy-livekit-testkit"
echo ""
echo "To stop and remove: docker rm -f ${CONTAINER_NAME}"
echo ""
echo "If WebRTC fails (e.g. browser clients), ensure ports ${LIVEKIT_ICE_TCP_PORT} and ${LIVEKIT_ICE_UDP_PORT} are free."
echo "Remove and recreate the container if it was created before WebRTC ports were added."
